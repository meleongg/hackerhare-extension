{
  "name": "hackerhare-extension",
  "displayName": "HackerHare",
  "version": "0.0.1",
  "description": "Privacy-first shield with on-device heuristics. Optional anonymous counter ping—no page data sent.",
  "author": "Melvin Teo",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "format": "prettier --write --no-error-on-unmatched-pattern \"popup.tsx\" \"components/**/*.{ts,tsx}\" \"contents/**/*.{ts,tsx}\" \"lib/**/*.{ts,tsx}\"",
    "icon:generate": "node scripts/generate-icon.mjs",
    "test:pages": "npx --yes serve test-pages -p 8080"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tldts": "^7.4.2"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@parcel/optimizer-data-url": "2.9.3",
    "@parcel/transformer-inline-string": "2.9.3",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "prettier": "3.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*"
    ]
  }
}
